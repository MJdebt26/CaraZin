# ─── CaraZin (Next.js + Supabase + Stripe) ───
# Copy to .env.local for local dev. In production set these in Vercel project settings.
# NEVER commit real keys.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — used by API routes for price validation, orders,
# stock decrement. Must NEVER be exposed to the client (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (test mode keys start with sk_test_)
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen --forward-to localhost:3000/api/webhook` (local) or the
# Stripe Dashboard webhook config (production).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL used for Stripe success/cancel redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
