# ─── CaraZin store configuration ───
# Copy to `.env` and fill in. The store runs with NONE of these set
# (mock checkout + default admin password), but set them for real use.

# Server
PORT=3000
# PUBLIC_URL is the externally reachable base URL. Needed so Stripe redirects
# back correctly in production. Leave unset for localhost.
# PUBLIC_URL=https://carazin.ca

# Admin dashboard (http://localhost:3000/admin.html)
ADMIN_PASSWORD=change-me-please
# Secret used to sign the admin session cookie — set to a long random string.
SESSION_SECRET=change-this-to-a-long-random-string

# Stripe (test mode keys start with sk_test_ / pk_test_)
# Get them at https://dashboard.stripe.com/test/apikeys
# If STRIPE_SECRET_KEY is left blank, the store uses MOCK checkout.
STRIPE_SECRET_KEY=
# For verifying webhooks. From `stripe listen` (local) or the Dashboard (prod).
STRIPE_WEBHOOK_SECRET=
